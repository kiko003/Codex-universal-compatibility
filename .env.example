# Codex Stripper Proxy Configuration
# Copy this file to .env and adjust values as needed

# Port the proxy listens on (default: 8080)
STRIPPER_PORT=8080

# Upstream LiteLLM (or any OpenAI-compatible) URL
STRIPPER_UPSTREAM=http://litellm:4000

# API key for the upstream proxy (set as Bearer token on forwarded requests)
UPSTREAM_API_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
STRIPPER_LOG_LEVEL=INFO

# Strip the "strict" field from tool definitions (many providers don't support it)
STRIP_STRICT=true
# Strip non-function tool types (e.g. tool_search, web_search) that providers like NVIDIA NIM reject
STRIP_NON_FUNCTION=true
